rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuth() && getUserRole() == 'admin';
    }

    function isMod() {
      return isAuth() && (getUserRole() == 'mod' || getUserRole() == 'admin');
    }

    // Users
    match /users/{uid} {
      allow read: if isAuth();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid)
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'banned']);
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Friends
    match /friends/{docId} {
      allow read: if isAuth() && request.auth.uid in resource.data.users;
      allow create: if isAuth() && request.auth.uid in request.resource.data.users;
      allow update: if isAuth() && request.auth.uid in resource.data.users;
      allow delete: if isAuth() && request.auth.uid in resource.data.users;
    }

    // Direct Messages
    match /directMessages/{channelId} {
      allow read: if isAuth() && request.auth.uid in resource.data.participants;
      allow create: if isAuth() && request.auth.uid in request.resource.data.participants;

      match /messages/{msgId} {
        allow read: if isAuth();
        allow create: if isAuth();
        allow delete: if isMod();
      }
    }

    // Servers
    match /servers/{serverId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth()
        && (request.auth.uid == resource.data.owner || isMod());
      allow delete: if isAdmin();

      match /channels/{channelId}/messages/{msgId} {
        allow read: if isAuth();
        allow create: if isAuth();
        allow delete: if isMod();
      }
    }

    // Games metadata
    match /games/{gameId} {
      allow read: if true;
      allow create: if isMod();
      allow update: if isMod();
      allow delete: if isAdmin();
    }
  }
}
