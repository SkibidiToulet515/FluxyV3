rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // One DM doc per user pair: path directMessages/{uidLo_uidHi}, participants sorted ascending.
    function dmCreateShapeValid(channelId) {
      let p = request.resource.data.participants;
      return p is list
        && p.size() == 2
        && p[0] is string
        && p[1] is string
        && request.auth.uid in p
        && p[0] < p[1]
        && channelId == p[0] + '_' + p[1];
    }

    function getUserRoleKey() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function roleDefPath() {
      return /databases/$(database)/documents/roleDefinitions/$(getUserRoleKey());
    }

    function actorPermissions() {
      return exists(roleDefPath())
        ? get(roleDefPath()).data.permissions
        : {};
    }

    function hasPerm(perm) {
      return isAuth() && actorPermissions()[perm] == true;
    }

    function hasLegacyRoleMgmt() {
      return hasPerm('manage_roles');
    }

    function hasAssignHigh() {
      return hasPerm('assign_high_roles') || hasLegacyRoleMgmt();
    }

    function hasAssignLow() {
      return hasPerm('assign_low_roles') || hasLegacyRoleMgmt();
    }

    function roleDefTierOf(roleKey) {
      let path = /databases/$(database)/documents/roleDefinitions/$(roleKey);
      return exists(path)
        ? (get(path).data.privilegeTier != null
            ? get(path).data.privilegeTier
            : (roleKey == 'owner' ? 'owner' : roleKey == 'admin' ? 'high' : 'low'))
        : (roleKey == 'owner' ? 'owner'
          : roleKey == 'admin' ? 'high'
          : roleKey == 'user' || roleKey == 'mod' ? 'low'
          : 'high');
    }

    function tierRankRule(t) {
      return t == 'owner' ? 3 : t == 'high' ? 2 : 1;
    }

    function targetUserRoleKey(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data.role;
    }

    function isAdmin() {
      return hasPerm('access_admin_panel');
    }

    function isMod() {
      return hasPerm('moderate_chat') || hasPerm('access_moderator_panel');
    }

    // ─── Role Definitions ─────────────────────────────────────────────
    match /roleDefinitions/{key} {
      allow read: if isAuth();
      allow create, update, delete: if false;
    }

    // ─── Moderation Logs ──────────────────────────────────────────────
    match /moderationLogs/{logId} {
      allow read: if hasPerm('access_moderator_panel');
      allow write: if false;
    }

    // ─── Reports ──────────────────────────────────────────────────────
    match /reports/{reportId} {
      allow create: if isAuth()
        && request.resource.data.reporterUid == request.auth.uid
        && request.resource.data.status == 'open';
      allow read: if hasPerm('access_moderator_panel');
      allow update: if hasPerm('manage_users');
      allow delete: if false;
    }

    // ─── Users ────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isAuth();
      allow create: if isOwner(uid)
        && request.resource.data.role == 'user';

      allow update: if isOwner(uid)
        && !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['role', 'banned', 'warnings', 'mutedUntil', 'chatRestricted', 'moderationNote'])
        && request.resource.data.role == resource.data.role
        && request.resource.data.keys().hasAll(['role', 'username', 'email']);

      allow update: if isAuth() && request.auth.uid != uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['role'])
        && (
          (roleDefTierOf(resource.data.role) == 'owner' || roleDefTierOf(request.resource.data.role) == 'owner')
            ? hasPerm('protect_owner')
          : (tierRankRule(roleDefTierOf(resource.data.role)) >= 2
            || tierRankRule(roleDefTierOf(request.resource.data.role)) >= 2)
            ? hasAssignHigh()
          : hasAssignLow()
        );

      allow update: if isAuth() && request.auth.uid != uid && hasPerm('ban_users')
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['banned'])
        && (
          roleDefTierOf(targetUserRoleKey(uid)) != 'owner'
          || hasPerm('protect_owner')
        );

      allow update: if isAuth() && request.auth.uid != uid && hasPerm('manage_users')
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['warnings', 'mutedUntil', 'chatRestricted', 'moderationNote'])
        && (
          roleDefTierOf(targetUserRoleKey(uid)) != 'owner'
          || hasPerm('protect_owner')
        );

      allow delete: if false;
    }

    // ─── Friends ──────────────────────────────────────────────────────
    // get: safe because doc ID is uid1_uid2 — caller must know both UIDs.
    // list: scoped to own friendships.
    // create: only the sender can create; status must start as pending.
    // update: ONLY the "to" user can accept a pending request.
    //         No other field mutations allowed.
    // delete: either participant (decline / cancel / remove).
    match /friends/{docId} {
      allow get: if isAuth();
      allow list: if isAuth() && request.auth.uid in resource.data.users;

      allow create: if isAuth()
        && request.auth.uid in request.resource.data.users
        && request.resource.data.users.size() == 2
        && request.resource.data.status == 'pending'
        && request.resource.data.from == request.auth.uid
        && request.resource.data.to != request.auth.uid;

      allow update: if isAuth()
        && request.auth.uid == resource.data.to
        && resource.data.status == 'pending'
        && request.resource.data.status == 'accepted'
        && request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['status', 'acceptedAt']);

      allow delete: if isAuth() && request.auth.uid in resource.data.users;
    }

    // ─── Direct Messages ──────────────────────────────────────────────
    match /directMessages/{channelId} {
      allow read: if isAuth() && request.auth.uid in resource.data.participants;
      allow create: if isAuth() && dmCreateShapeValid(channelId);
      allow update: if isAuth() && request.auth.uid in resource.data.participants
        && request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['lastMessage', 'lastMessageAt', 'lastSenderUid']);

      match /messages/{msgId} {
        allow read: if isAuth()
          && request.auth.uid in
             get(/databases/$(database)/documents/directMessages/$(channelId)).data.participants;

        allow create: if isAuth()
          && request.resource.data.senderUid == request.auth.uid;

        allow update: if isAuth()
          && resource.data.senderUid == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['text', 'editedAt'])
          && request.resource.data.senderUid == resource.data.senderUid;

        // Reactions: dot paths like reactions.👍 appear in affectedKeys — forbid edits
        // to core fields instead of requiring hasOnly(['reactions']).
        allow update: if isAuth()
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
            'senderUid', 'text', 'createdAt', 'editedAt', 'gif', 'image',
            'attachment', 'senderUsername', 'senderAvatar', 'senderColor'
          ]);

        allow delete: if isAuth()
          && (resource.data.senderUid == request.auth.uid
            || hasPerm('moderate_chat'));
      }
    }

    // ─── Group Chats ──────────────────────────────────────────────────
    match /groupChats/{groupId} {
      allow read: if isAuth() && request.auth.uid in resource.data.members;
      allow create: if isAuth()
        && request.auth.uid == request.resource.data.owner
        && request.auth.uid in request.resource.data.members;

      // Owner can change anything.
      allow update: if isAuth() && request.auth.uid == resource.data.owner;

      // Non-owner members: message metadata or self-leave only.
      allow update: if isAuth()
        && request.auth.uid in resource.data.members
        && request.auth.uid != resource.data.owner
        && (
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['lastMessage', 'lastMessageAt', 'lastSenderUid'])
          || (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members'])
            && !(request.auth.uid in request.resource.data.members)
          )
        );

      allow delete: if isAuth() && request.auth.uid == resource.data.owner;

      match /messages/{msgId} {
        allow read: if isAuth()
          && request.auth.uid in
             get(/databases/$(database)/documents/groupChats/$(groupId)).data.members;

        allow create: if isAuth()
          && request.resource.data.senderUid == request.auth.uid;

        allow update: if isAuth()
          && resource.data.senderUid == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['text', 'editedAt'])
          && request.resource.data.senderUid == resource.data.senderUid;

        allow update: if isAuth()
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
            'senderUid', 'text', 'createdAt', 'editedAt', 'gif', 'image',
            'attachment', 'senderUsername', 'senderAvatar', 'senderColor'
          ]);

        allow delete: if isAuth()
          && (resource.data.senderUid == request.auth.uid
            || hasPerm('moderate_chat'));
      }
    }

    // ─── Servers ──────────────────────────────────────────────────────
    match /servers/{serverId} {
      allow read: if isAuth();

      allow create: if isAuth()
        && request.auth.uid == request.resource.data.owner
        && request.auth.uid in request.resource.data.members;

      // Owner can change anything.
      allow update: if isAuth() && request.auth.uid == resource.data.owner;

      // Existing members (non-owner): anything except owner/createdAt.
      allow update: if isAuth()
        && request.auth.uid in resource.data.members
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['owner', 'createdAt']);

      // Platform mods: anything except owner/createdAt.
      allow update: if isMod()
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['owner', 'createdAt']);

      // Self-join: non-member can add ONLY themselves; existing members
      // must remain (superset check prevents kicking others).
      allow update: if isAuth()
        && !(request.auth.uid in resource.data.members)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members'])
        && request.auth.uid in request.resource.data.members
        && request.resource.data.members.hasAll(resource.data.members);

      // Default community server: only admins may delete (owners cannot nuke global hub).
      allow delete: if isAuth() && request.auth.uid == resource.data.owner
        && serverId != 'fluxy-community';
      allow delete: if isAdmin() && serverId != 'fluxy-community';

      match /channels/{channelId}/messages/{msgId} {
        allow read: if isAuth();

        allow create: if isAuth()
          && request.resource.data.senderUid == request.auth.uid;

        allow update: if isAuth()
          && resource.data.senderUid == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['text', 'editedAt'])
          && request.resource.data.senderUid == resource.data.senderUid;

        allow update: if isAuth()
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
            'senderUid', 'text', 'createdAt', 'editedAt', 'gif', 'image',
            'attachment', 'senderUsername', 'senderAvatar', 'senderColor'
          ]);

        allow delete: if isAuth()
          && (resource.data.senderUid == request.auth.uid
            || hasPerm('moderate_chat'));
      }
    }

    // ─── Server Invites ───────────────────────────────────────────────
    // Each document is server-bound: `serverId` identifies the only server this code can join.
    // Updates may only bump `uses` (immutable server binding; enforced by affectedKeys).
    match /serverInvites/{inviteCode} {
      allow read: if isAuth();

      // Only server members may create invites for that server (createdBy must match).
      allow create: if isAuth()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.uses == 0
        && request.resource.data.serverId is string
        && exists(/databases/$(database)/documents/servers/$(request.resource.data.serverId))
        && request.auth.uid in get(/databases/$(database)/documents/servers/$(request.resource.data.serverId)).data.members;

      // Only the uses counter can change, and only by exactly +1.
      // Server-side maxUses enforcement prevents exceeding the cap.
      // Immutable invite binding: one code → one server (serverId cannot drift).
      allow update: if isAuth()
        && request.resource.data.serverId == resource.data.serverId
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['uses'])
        && request.resource.data.uses == resource.data.uses + 1
        && (resource.data.maxUses == 0
          || request.resource.data.uses <= resource.data.maxUses);

      allow delete: if isAuth()
        && (resource.data.createdBy == request.auth.uid || isAdmin());
    }

    // ─── Games ────────────────────────────────────────────────────────
    match /games/{gameId} {
      allow read: if true;
      allow create, update: if hasPerm('manage_games');
      allow delete: if isAdmin();
    }

    // Giveaways + entries — all writes via Cloud API (Admin SDK)
    match /giveaways/{giveawayId} {
      allow read: if isAuth();
      allow create, update, delete: if false;
    }
    match /giveawayEntries/{entryId} {
      allow read, write: if false;
    }
  }
}
