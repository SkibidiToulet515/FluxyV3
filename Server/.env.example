# Fluxy Server Configuration
# Copy this file to .env and adjust values as needed.

# Server port
PORT=3000

# Client origin(s) for CORS — comma-separated exact origins (no wildcards).
# Production: list your Hosting URL(s), e.g. https://your-app.web.app,https://your-app.firebaseapp.com
CLIENT_ORIGIN=http://localhost:5173
# Optional extra allowed origins (comma-separated), e.g. preview deploys or alternate domains
# CORS_EXTRA_ORIGINS=

# API rate limit: max JSON requests per IP per minute under /api (default 200)
# API_RATE_LIMIT_PER_MIN=200

# Socket.io: require Firebase ID token in handshake (auth.token or ?token=). Set false only for local dev without Firebase Admin.
# SOCKET_AUTH_REQUIRED=true

# --- Web Engine Providers ---
# Set to "false" to disable a provider entirely.
SCRAMJET_ENABLED=true
UV_ENABLED=true

# --- Giphy ---
# Required for GIF search in chat. Get yours at https://developers.giphy.com/
GIPHY_API_KEY=

# --- Firebase Admin ---
# Required for admin features, username→email login, etc.
FIREBASE_PROJECT_ID=
# Local: path to service account JSON (relative to process cwd, usually Server/)
# FIREBASE_SERVICE_ACCOUNT=./serviceAccountKey.json
# App Hosting / Cloud Run: paste the entire JSON as one line (use Secret Manager)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# --- Admin Seed ---
# Used by scripts/seed-admin.js to create the initial admin account
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASS=CHANGE_ME_BEFORE_USE
